{
  "rewrites": [
    { "source": "/install", "destination": "/install" },
    { "source": "/**", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/install",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Content-Disposition", "value": "inline" }
      ]
    }
  ]
}
