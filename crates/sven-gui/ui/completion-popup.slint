//
// Slash command completion popup — floats as an overlay above the input box.
// Rendered at the window level; the InputPane is NOT responsible for its
// position. Place this component last in the window stacking order so it
// paints on top.

import { Theme } from "theme.slint";

export struct CompletionEntry {
    value: string,
    display: string,
    description: string,
}

export component CompletionPopup inherits Rectangle {
    in property <[CompletionEntry]> items;
    in property <int>               selected-index: 0;

    callback accepted(string);
    callback dismissed();

    background: transparent;
    visible: items.length > 0;

    property <length> panel-height: Math.min(items.length * 28px + 12px, 220px);

    // Position above the input area so it doesn't occlude the input box
    property <length> panel-y: root.height - Theme.input-area-height - root.panel-height - 6px;

    // Click outside to dismiss (backdrop)
    TouchArea {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        clicked => { root.dismissed(); }
    }

    popup-panel := Rectangle {
        x: Theme.space-lg;
        y: root.panel-y;
        width: Math.min(parent.width - Theme.space-lg * 2, 560px);
        height: root.panel-height;
        border-radius: Theme.radius-md;
        background: Theme.bg-card;
        border-color: Theme.accent-dim;
        border-width: 1px;

        // Drop shadow effect via inner rect
        drop-shadow-blur: 16px;
        drop-shadow-color: #00000060;

        VerticalLayout {
            padding: Theme.space-xs;
            spacing: 2px;

            Flickable {
                width: parent.width - 2 * Theme.space-xs;
                height: root.panel-height - 2 * Theme.space-xs;
                viewport-height: item-layout.preferred-height;
                interactive: true;

                item-layout := VerticalLayout {
                    width: parent.width;
                    spacing: 1px;
                    alignment: start;

                    for item[i] in items: Rectangle {
                        height: 26px;
                        border-radius: Theme.radius-sm;
                        background: i == selected-index ? Theme.bg-active
                                  : item-ta.has-hover    ? Theme.bg-hover
                                  : transparent;

                        border-color: i == selected-index ? Theme.accent-dim : transparent;
                        border-width: i == selected-index ? 1px : 0px;

                        item-ta := TouchArea {
                            clicked => { root.accepted(item.value); }
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-sm;
                            padding-right: Theme.space-sm;
                            spacing: Theme.space-xs;
                            alignment: start;

                            // Command name (display already includes "/" when applicable)
                            Text {
                                text: item.display != "" ? item.display : ("/" + item.value);
                                color: i == selected-index ? Theme.text-primary : Theme.text-secondary;
                                font-size: Theme.font-size-sm;
                                font-weight: 600;
                                font-family: Theme.font-mono;
                                vertical-alignment: center;
                                width: 120px;
                            }

                            // Description
                            if item.description != "": Text {
                                text: item.description;
                                color: Theme.text-dim;
                                font-size: Theme.font-size-sm;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }

                            // Tab hint on selected
                            if i == selected-index: Text {
                                text: "Tab";
                                color: Theme.text-dim;
                                font-size: 11px;
                                font-family: Theme.font-mono;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                            }
                        }
                    }
                }
            }
        }
    }
}
