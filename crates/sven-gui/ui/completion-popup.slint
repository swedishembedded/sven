//
// Slash command completion popup with full keyboard navigation.
// Rendered as a window-level overlay above the input pane.

import { Theme } from "theme.slint";

export struct CompletionEntry {
    value: string,
    display: string,
    description: string,
}

export component CompletionPopup inherits Rectangle {
    in property <[CompletionEntry]> items;
    in-out property <int>           selected-index: 0;

    callback accepted(string);
    callback dismissed();
    callback selection-changed(int);

    background: transparent;
    visible: items.length > 0;

    property <length> item-height: 28px;
    property <length> panel-height: Math.min(items.length * item-height + 12px, 220px);
    property <length> panel-y: root.height - Theme.input-area-default - root.panel-height - 6px;

    // Backdrop
    TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        clicked => { root.dismissed(); }
    }

    // Key navigation via a FocusScope at the window level is handled by
    // MainWindow, which updates `selected-index` and calls `accepted` /
    // `dismissed`.  The popup itself only renders.

    popup-panel := Rectangle {
        x: Theme.space-lg;
        y: root.panel-y;
        width: Math.min(parent.width - Theme.space-lg * 2, 560px);
        height: root.panel-height;
        border-radius: Theme.radius-md;
        background: Theme.bg-card;
        border-color: Theme.accent-dim;
        border-width: 1px;
        drop-shadow-blur: Theme.shadow-blur-md;
        drop-shadow-color: Theme.shadow-color-md;

        VerticalLayout {
            padding: Theme.space-xs;
            spacing: 2px;

            Flickable {
                width: parent.width - 2 * Theme.space-xs;
                height: root.panel-height - 2 * Theme.space-xs;
                viewport-height: item-layout.preferred-height;
                interactive: true;

                item-layout := VerticalLayout {
                    width: parent.width;
                    spacing: 1px;
                    alignment: start;

                    for item[i] in items: Rectangle {
                        height: root.item-height;
                        border-radius: Theme.radius-sm;
                        background:
                            i == selected-index ? Theme.bg-active :
                            item-ta.has-hover    ? Theme.bg-hover  :
                            transparent;
                        border-color: i == selected-index ? Theme.accent-dim : transparent;
                        border-width: i == selected-index ? 1px : 0px;
                        animate background { duration: Theme.duration-fast; }

                        item-ta := TouchArea {
                            clicked => {
                                root.selected-index = i;
                                root.accepted(item.value);
                            }
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-sm;
                            padding-right: Theme.space-sm;
                            spacing: Theme.space-xs;
                            alignment: start;

                            Text {
                                text: item.display != "" ? item.display : ("/" + item.value);
                                color: i == selected-index ? Theme.text-primary : Theme.text-secondary;
                                font-size: Theme.font-size-sm;
                                font-weight: 600;
                                font-family: Theme.font-mono;
                                vertical-alignment: center;
                                width: 130px;
                            }

                            if item.description != "": Text {
                                text: item.description;
                                color: Theme.text-dim;
                                font-size: Theme.font-size-sm;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }

                            if i == selected-index: Text {
                                text: "Tab ↵";
                                color: Theme.text-dim;
                                font-size: Theme.font-size-xs;
                                font-family: Theme.font-mono;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                            }
                        }
                    }
                }
            }
        }
    }
}
