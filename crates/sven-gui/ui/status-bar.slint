// Status bar at the top of the main window.

import { Theme }       from "theme.slint";
import { ProgressBar } from "widgets.slint";

export component StatusBar inherits Rectangle {
    in property <string> model-name: "claude";
    in property <string> mode: "agent";
    in property <int>    context-pct: 0;
    in property <bool>   agent-busy: false;
    in property <float>  total-cost-usd: 0.0;
    in property <int>    total-output-tokens: 0;
    in property <int>    total-input-tokens: 0;
    in property <string> connection-label: "local";
    in property <bool>   is-node-proxy: false;

    callback model-clicked();
    callback mode-clicked();
    callback help-clicked();

    height: Theme.status-bar-height;
    background: Theme.bg-surface;

    // Bottom border
    Rectangle {
        x: 0; y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: Theme.border;
    }

    HorizontalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        spacing: Theme.space-md;
        alignment: space-between;

        // ── Left: logo + model + mode ─────────────────────────────────────────
        HorizontalLayout {
            spacing: Theme.space-sm;
            alignment: start;

            Text {
                text: "⬡ sven";
                color: Theme.accent;
                font-size: Theme.font-size-md;
                font-weight: 700;
                vertical-alignment: center;
            }

            // Divider
            Rectangle {
                width: 1px; height: 16px;
                y: (parent.height - self.height) / 2;
                background: Theme.border;
            }

            // Clickable model
            model-area := TouchArea {
                height: parent.height;
                width: model-text.preferred-width + 12px;
                clicked => { root.model-clicked(); }

                model-text := Text {
                    text: root.model-name;
                    color: model-area.has-hover ? Theme.accent : Theme.text-primary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                    x: 6px;
                    animate color { duration: Theme.duration-fast; }
                }
            }

            Text {
                text: "·";
                color: Theme.text-dim;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
            }

            // Clickable mode with hover background
            mode-area := TouchArea {
                height: parent.height;
                width: mode-text.preferred-width + 12px;
                clicked => { root.mode-clicked(); }

                Rectangle {
                    x: 0; y: (parent.height - 20px) / 2;
                    width: parent.width; height: 20px;
                    border-radius: Theme.radius-sm;
                    background: mode-area.has-hover ? Theme.bg-hover : transparent;
                    animate background { duration: Theme.duration-fast; }
                }

                mode-text := Text {
                    text: root.mode;
                    color: mode-area.has-hover ? Theme.accent : Theme.info;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                    x: 6px;
                    animate color { duration: Theme.duration-fast; }
                }
            }
        }

        // ── Right: metrics ────────────────────────────────────────────────────
        HorizontalLayout {
            spacing: Theme.space-md;
            alignment: end;

            // Busy indicator
            if root.agent-busy: HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: center;
                Text {
                    text: "⟳ thinking";
                    color: Theme.accent;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                }
            }

            // Context bar (uses ProgressBar widget)
            Rectangle {
                width: 72px;
                y: (parent.height - self.height) / 2;
                ProgressBar {
                    width: parent.width;
                    value: root.context-pct;
                }
            }

            if total-input-tokens > 0: Text {
                text: "in:" + Math.floor(total-input-tokens / 1000) + "k";
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
            }

            if total-output-tokens > 0: Text {
                text: "out:" + Math.floor(total-output-tokens / 1000) + "k";
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
            }

            if root.total-cost-usd > 0: Text {
                text: "$" + Math.round(root.total-cost-usd * 100) / 100.0;
                color: Theme.text-dim;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
            }

            Text {
                text: root.is-node-proxy ? "⬡ " + root.connection-label : "⬡ local";
                color: root.is-node-proxy ? Theme.info : Theme.text-dim;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
            }

            // F1 help button
            help-area := TouchArea {
                height: parent.height;
                width: 28px;
                clicked => { root.help-clicked(); }

                Rectangle {
                    x: 0; y: (parent.height - 20px) / 2;
                    width: 28px; height: 20px;
                    border-radius: Theme.radius-sm;
                    background: help-area.has-hover ? Theme.bg-hover : transparent;
                    animate background { duration: Theme.duration-fast; }

                    Text {
                        text: "F1";
                        color: help-area.has-hover ? Theme.accent : Theme.text-dim;
                        font-size: Theme.font-size-xs;
                        font-family: Theme.font-mono;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                        animate color { duration: Theme.duration-fast; }
                    }
                }
            }
        }
    }
}
