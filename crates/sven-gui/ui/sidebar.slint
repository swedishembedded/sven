// Session list sidebar with search, delete, rename, and cost display.

import { Theme } from "theme.slint";
import { IconButton, SearchInput, RotatingSpinner } from "widgets.slint";

export struct SessionItem {
    id: string,
    title: string,
    busy: bool,
    active: bool,
    depth: int,
    status: string,
    total-cost-usd: float,
}

component SessionRow inherits Rectangle {
    in property <SessionItem> item;
    in property <int> index;
    in property <length> row-width: Theme.sidebar-width;
    callback clicked(int);
    callback delete-clicked(string);
    callback rename-clicked(string, string);

    width: row-width;
    height: Theme.row-height;
    background: ta.has-hover ? Theme.bg-hover : (item.active ? Theme.bg-active : transparent);
    animate background { duration: Theme.duration-fast; }

    // Active indicator bar
    if item.active: Rectangle {
        x: 0;
        y: (root.height - 24px) / 2;
        width: 2px;
        height: 24px;
        background: Theme.accent;
        border-radius: 1px;
    }

    // TouchArea drawn first (underneath) so IconButton can receive clicks when on top
    ta := TouchArea {
        clicked => { root.clicked(root.index); }
    }

    VerticalLayout {
        padding-left: Theme.space-sm + item.depth * 16px + (item.active ? 6px : 4px);
        padding-right: Theme.space-xs;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 2px;
        alignment: center;

        HorizontalLayout {
            spacing: Theme.space-xs;
            alignment: space-between;

            // Left: status + title
            HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: center;
                horizontal-stretch: 1;
                min-width: 0;

                // Status indicator
                if item.busy: RotatingSpinner {
                    width: 14px;
                    height: 14px;
                }
                if !item.busy: Text {
                    text: item.status == "completed" ? "✓" :
                          item.status == "archived"  ? "◉" : "○";
                    color: item.status == "completed" ? Theme.success :
                           item.status == "archived"  ? Theme.text-dim : Theme.text-dim;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                    width: 14px;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    min-width: 0;
                    Text {
                        text: item.title;
                        color: item.active ? Theme.text-primary : Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        overflow: elide;
                        width: parent.width;
                    }
                }
            }

            // Right: cost + delete (aligned to end)
            HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: end;

                // Cost badge (non-zero)
                if item.total-cost-usd > 0.0: Text {
                    text: "$" + Math.round(item.total-cost-usd * 100) / 100.0;
                    color: Theme.text-dim;
                    font-size: Theme.font-size-xs;
                    font-family: Theme.font-mono;
                    vertical-alignment: center;
                }

                // Action buttons (visible on row hover or button hover)
                HorizontalLayout {
                    spacing: 1px;
                    opacity: (ta.has-hover || delete-btn.has-hover) ? 1.0 : 0.0;
                    animate opacity { duration: Theme.duration-fast; }

                    delete-btn := IconButton {
                        icon: "✕";
                        destructive: true;
                        tooltip-text: "Delete session";
                        clicked => { root.delete-clicked(root.item.id); }
                    }
                }
            }
        }
    }
}

export component Sidebar inherits Rectangle {
    in property <[SessionItem]>  sessions;
    in property <string>         active-session-id;
    in-out property <string>     search-text: "";

    callback session-selected(string);
    callback new-session();
    callback session-delete-requested(string);
    callback session-rename-requested(string, string);
    callback search-changed(string);

    width: Theme.sidebar-width;
    background: Theme.bg-surface;

    VerticalLayout {
        spacing: 0;

        // ── Header ────────────────────────────────────────────────────────────
        Rectangle {
            height: 40px;
            background: Theme.bg-surface;

            HorizontalLayout {
                padding-left: Theme.space-md;
                padding-right: Theme.space-sm;
                spacing: 0;
                alignment: space-between;

                Text {
                    text: "Conversations";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: Theme.radius-sm;
                    background: new-ta.has-hover ? Theme.bg-active : transparent;
                    animate background { duration: Theme.duration-fast; }

                    Text {
                        text: "+";
                        color: new-ta.has-hover ? Theme.accent : Theme.text-secondary;
                        font-size: 18px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: Theme.duration-fast; }
                    }

                    new-ta := TouchArea {
                        clicked => { root.new-session(); }
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: Theme.border-dim;
            }
        }

        // ── Search bar ────────────────────────────────────────────────────────
        Rectangle {
            height: 40px;
            background: Theme.bg-surface;

            SearchInput {
                x: Theme.space-sm;
                y: Theme.space-xs;
                width: parent.width - 2 * Theme.space-sm;
                height: parent.height - 2 * Theme.space-xs;
                placeholder: "Filter sessions…";
                text <=> root.search-text;
                text-changed(t) => { root.search-changed(t); }
            }
        }

        // ── Session list ──────────────────────────────────────────────────────
        Rectangle {
            vertical-stretch: 1;
            clip: true;

            Flickable {
                width: parent.width;
                height: parent.height;
                viewport-height: session-list.preferred-height;
                interactive: true;

                session-list := VerticalLayout {
                    width: parent.width;
                    spacing: 0;
                    alignment: start;

                    for item[i] in root.sessions: SessionRow {
                        item: item;
                        index: i;
                        row-width: root.width;
                        clicked(idx) => {
                            if idx < root.sessions.length {
                                root.session-selected(root.sessions[idx].id);
                            }
                        }
                        delete-clicked(id) => { root.session-delete-requested(id); }
                        rename-clicked(id, title) => { root.session-rename-requested(id, title); }
                    }
                }
            }
        }
    }

    // Right border
    Rectangle {
        x: parent.width - 1px;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Theme.border;
    }
}
