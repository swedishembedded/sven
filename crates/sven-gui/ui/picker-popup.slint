//
// Generic picker popup with live search-filter support.
// The visible item list is filtered server-side (bridge.rs) via the
// `search-changed` callback; Rust updates `items` with the filtered subset.

import { Theme } from "theme.slint";

export struct PickerItem {
    id: string,
    label: string,
    description: string,
}

export component PickerPopup inherits Rectangle {
    in property <string>       title: "Select";
    in property <[PickerItem]> items;

    callback selected(string);
    callback dismissed();
    callback search-changed(string);   // fired on every keystroke; Rust filters items

    background: #00000090;

    // Dismiss on backdrop click
    TouchArea { clicked => { root.dismissed(); } }

    // ── Floating panel ────────────────────────────────────────────────────────
    panel := Rectangle {
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        width: 520px;
        height: Math.min(parent.height - 80px, 540px);
        border-radius: Theme.radius-lg;
        background: Theme.bg-surface;
        border-color: Theme.border;
        border-width: 1px;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000080;

        // Swallow clicks inside panel
        TouchArea { }

        VerticalLayout {
            padding: Theme.space-md;
            spacing: Theme.space-sm;

            // ── Title ─────────────────────────────────────────────────────────
            Text {
                text: title;
                color: Theme.accent;
                font-size: Theme.font-size-md;
                font-weight: 700;
            }

            // ── Search input ──────────────────────────────────────────────────
            Rectangle {
                height: 36px;
                border-radius: Theme.radius-sm;
                border-color: search-input.has-focus ? Theme.accent-dim : Theme.border;
                border-width: 1px;
                background: Theme.bg-deep;

                HorizontalLayout {
                    padding-left: Theme.space-sm;
                    padding-right: Theme.space-sm;
                    spacing: Theme.space-xs;
                    alignment: start;

                    Text {
                        text: "🔍";
                        font-size: Theme.font-size-sm;
                        color: Theme.text-dim;
                        vertical-alignment: center;
                        width: 20px;
                    }

                    search-input := TextInput {
                        width: parent.width - 36px;
                        height: parent.height;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-base;
                        single-line: true;

                        edited => { root.search-changed(self.text); }
                        accepted => { }
                    }

                    if search-input.text == "": Text {
                        text: "Filter…";
                        color: Theme.text-dim;
                        font-size: Theme.font-size-base;
                        vertical-alignment: center;
                    }
                }
            }

            // ── Item list ─────────────────────────────────────────────────────
            Rectangle {
                vertical-stretch: 1;
                clip: true;
                border-radius: Theme.radius-sm;

                Flickable {
                    width: parent.width;
                    height: parent.height;
                    viewport-height: list-layout.preferred-height;
                    interactive: true;

                    list-layout := VerticalLayout {
                        width: parent.width;
                        spacing: 2px;
                        alignment: start;

                        for item in items: Rectangle {
                            height: 52px;
                            border-radius: Theme.radius-sm;
                            background: row-ta.has-hover ? Theme.bg-hover : transparent;

                            row-ta := TouchArea {
                                clicked => { root.selected(item.id); }
                            }

                            HorizontalLayout {
                                padding: Theme.space-sm;
                                spacing: Theme.space-sm;
                                alignment: start;

                                Rectangle {
                                    width: 3px;
                                    height: 32px;
                                    border-radius: 2px;
                                    background: row-ta.has-hover ? Theme.accent-dim : transparent;
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    horizontal-stretch: 1;

                                    Text {
                                        text: item.label;
                                        color: Theme.text-primary;
                                        font-size: Theme.font-size-base;
                                        font-weight: 600;
                                        overflow: elide;
                                    }

                                    if item.description != "": Text {
                                        text: item.description;
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-size-sm;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ── Footer hint ───────────────────────────────────────────────────
            Text {
                text: "Click to select  •  Esc to dismiss";
                color: Theme.text-dim;
                font-size: 11px;
                font-family: Theme.font-mono;
                horizontal-alignment: center;
            }
        }
    }
}
