// Generic picker popup with live search-filter and full keyboard navigation.

import { Theme } from "theme.slint";
import { SearchInput } from "widgets.slint";

export struct PickerItem {
    id: string,
    label: string,
    description: string,
}

export component PickerPopup inherits Rectangle {
    in property <string>       title: "Select";
    in property <[PickerItem]> items;
    in property <bool>         show-search: true;

    callback selected(string);
    callback dismissed();
    callback search-changed(string);

    in-out property <int> keyboard-index: 0;

    background: #00000090;
    TouchArea { clicked => { root.dismissed(); } }

    FocusScope {
        width: parent.width;
        height: parent.height;
        key-pressed(event) => {
            if event.text == Key.Escape {
                root.dismissed();
                accept
            } else if event.text == Key.UpArrow {
                if root.keyboard-index > 0 {
                    root.keyboard-index -= 1;
                }
                accept
            } else if event.text == Key.DownArrow {
                if root.keyboard-index < root.items.length - 1 {
                    root.keyboard-index += 1;
                }
                accept
            } else if event.text == Key.Return {
                if root.keyboard-index < root.items.length {
                    root.selected(root.items[root.keyboard-index].id);
                }
                accept
            } else {
                reject
            }
        }

        panel := Rectangle {
            x: (parent.width  - self.width)  / 2;
            y: (parent.height - self.height) / 2;
            width: Theme.modal-width;
            height: Math.min(parent.height - 80px, 540px);
            border-radius: Theme.radius-lg;
            background: Theme.bg-surface;
            border-color: Theme.border;
            border-width: 1px;
            drop-shadow-blur: Theme.shadow-blur-lg;
            drop-shadow-color: Theme.shadow-color-lg;

            VerticalLayout {
                padding: Theme.space-md;
                spacing: Theme.space-sm;

                Text {
                    text: title;
                    color: Theme.accent;
                    font-size: Theme.font-size-md;
                    font-weight: 700;
                }

                if root.show-search: search-box := SearchInput {
                    placeholder: "Filter…";
                    text-changed(t) => { root.search-changed(t); }
                }

                // Empty state
                if root.items.length == 0: Rectangle {
                    height: 60px;
                    Text {
                        text: "No items found";
                        color: Theme.text-dim;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }

                if root.items.length > 0: Rectangle {
                    vertical-stretch: 1;
                    clip: true;
                    border-radius: Theme.radius-sm;

                    Flickable {
                        width: parent.width;
                        height: parent.height;
                        viewport-height: list-layout.preferred-height;
                        interactive: true;

                        list-layout := VerticalLayout {
                            width: parent.width;
                            spacing: 2px;
                            alignment: start;

                            for item[i] in items: Rectangle {
                                height: 52px;
                                border-radius: Theme.radius-sm;
                                background:
                                    i == root.keyboard-index ? Theme.bg-active :
                                    row-ta.has-hover ? Theme.bg-hover :
                                    transparent;
                                border-color: i == root.keyboard-index ? Theme.accent-dim : transparent;
                                border-width: i == root.keyboard-index ? 1px : 0px;
                                animate background { duration: Theme.duration-fast; }

                                row-ta := TouchArea {
                                    clicked => {
                                        root.keyboard-index = i;
                                        root.selected(item.id);
                                    }
                                }

                                HorizontalLayout {
                                    padding: Theme.space-sm;
                                    spacing: Theme.space-sm;
                                    alignment: start;

                                    Rectangle {
                                        width: 3px;
                                        height: 32px;
                                        border-radius: 2px;
                                        background: (i == root.keyboard-index || row-ta.has-hover) ? Theme.accent-dim : transparent;
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        horizontal-stretch: 1;

                                        Text {
                                            text: item.label;
                                            color: i == root.keyboard-index ? Theme.text-primary : Theme.text-secondary;
                                            font-size: Theme.font-size-base;
                                            font-weight: i == root.keyboard-index ? 600 : 400;
                                            overflow: elide;
                                        }

                                        if item.description != "": Text {
                                            text: item.description;
                                            color: Theme.text-dim;
                                            font-size: Theme.font-size-sm;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                Text {
                    text: "↑↓ navigate · Enter select · Esc dismiss";
                    color: Theme.text-dim;
                    font-size: Theme.font-size-xs;
                    font-family: Theme.font-mono;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
