// Queue panel — pending messages above the input, with edit/delete/submit actions.

import { Theme } from "theme.slint";

export struct QueueItem {
    index: int,
    content: string,
}

export component QueuePanel inherits Rectangle {
    in property <[QueueItem]> items;
    callback edit-clicked(int);
    callback delete-clicked(int);
    callback submit-clicked(int);

    visible: items.length > 0;
    height: root.visible ? (items.length * 36px + Theme.space-sm * 2) : 0px;
    background: Theme.bg-surface;

    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: 1px;
        background: Theme.border;
    }

    VerticalLayout {
        padding: Theme.space-sm;
        spacing: 2px;
        alignment: start;

        for item in items: Rectangle {
            height: 34px;
            border-radius: Theme.radius-sm;
            background: row-ta.has-hover ? Theme.bg-hover : transparent;

            row-ta := TouchArea {
                height: parent.height;
                width: parent.width;
            }

            HorizontalLayout {
                padding-left: Theme.space-sm;
                padding-right: Theme.space-xs;
                spacing: Theme.space-xs;
                alignment: center;

                // Content preview (truncated)
                Text {
                    horizontal-stretch: 1;
                    text: item.content;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    overflow: elide;
                    vertical-alignment: center;
                }

                // Icon buttons aligned right
                HorizontalLayout {
                    spacing: 2px;
                    alignment: end;

                    edit-btn := Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 4px;
                        background: edit-ta.has-hover ? Theme.bg-hover : transparent;

                        Text {
                            text: "✎";
                            color: Theme.text-dim;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        edit-ta := TouchArea {
                            clicked => { root.edit-clicked(item.index); }
                        }
                    }

                    del-btn := Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 4px;
                        background: del-ta.has-hover ? Theme.error-bg : transparent;

                        Text {
                            text: "✕";
                            color: Theme.text-dim;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        del-ta := TouchArea {
                            clicked => { root.delete-clicked(item.index); }
                        }
                    }

                    submit-btn := Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 4px;
                        background: submit-ta.has-hover ? Theme.accent-dim : transparent;

                        Text {
                            text: "▶";
                            color: Theme.accent;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        submit-ta := TouchArea {
                            clicked => { root.submit-clicked(item.index); }
                        }
                    }
                }
            }
        }
    }
}
