// Scrollable chat message pane with markdown block rendering.

import { Theme } from "theme.slint";

export struct ChatMessage {
    // Core classification
    message-type: string,   // user|assistant|code-block|heading|list-item|separator|thinking|tool-call|tool-result|error|system|block-quote
    content: string,
    role: string,

    // Group header
    is-first-in-group: bool, // show "⬡ Sven" or "◎ Thinking" header

    // State
    is-error: bool,
    is-streaming: bool,
    is-expanded: bool,      // thinking/tool-call: expanded = show full content

    // Tool call fields
    tool-name: string,
    tool-icon: string,
    tool-summary: string,
    tool-category: string,
    tool-fields-json: string, // JSON-encoded [{k, v}] pairs for expanded view

    // Code block fields
    language: string,
    heading-level: int,     // 1–6
}

// ── User bubble ───────────────────────────────────────────────────────────────

component UserBubble inherits Rectangle {
    in property <string> content;
    in property <length> available-width: 600px;

    width: available-width;
    border-radius: Theme.radius-md;
    background: Theme.user-msg-bg;
    border-color: Theme.user-msg-border;
    border-width: 1px;

    VerticalLayout {
        padding: Theme.space-md;
        spacing: Theme.space-xs;

        Text {
            text: "You";
            color: Theme.info;
            font-size: Theme.font-size-sm;
            font-weight: 700;
        }

        Text {
            text: content;
            color: Theme.text-primary;
            font-size: Theme.font-size-base;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }
    }
}

// ── Assistant paragraph ───────────────────────────────────────────────────────

component AssistantParagraph {
    in property <string> content;
    in property <bool>   is-streaming: false;
    in property <bool>   show-header: false;
    in property <length> available-width: 600px;

    width: available-width;

    VerticalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: show-header ? Theme.space-md : 0;
        padding-bottom: Theme.space-xs;
        spacing: Theme.space-xs;

        if show-header: HorizontalLayout {
            spacing: Theme.space-xs;
            alignment: start;
            Text {
                text: "⬡ Sven";
                color: Theme.accent;
                font-size: Theme.font-size-sm;
                font-weight: 700;
            }
            if is-streaming: Text {
                text: "▋";
                color: Theme.accent;
                font-size: Theme.font-size-sm;
            }
        }

        Text {
            text: content;
            color: Theme.text-primary;
            font-size: Theme.font-size-base;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }
    }
}

// ── Code block ────────────────────────────────────────────────────────────────

component CodeBlockBubble {
    in property <string> content;
    in property <string> language: "";
    in property <length> available-width: 600px;

    width: available-width;

    VerticalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-bottom: Theme.space-xs;

        Rectangle {
            border-radius: Theme.radius-sm;
            background: Theme.code-bg;
            border-color: Theme.code-border;
            border-width: 1px;

            VerticalLayout {
                padding: Theme.space-sm;
                spacing: Theme.space-xs;

                if language != "": HorizontalLayout {
                    padding-left: Theme.space-xs;
                    Text {
                        text: language;
                        color: Theme.text-dim;
                        font-size: Theme.font-size-sm;
                    }
                }

                Text {
                    text: content;
                    color: Theme.text-code;
                    font-size: Theme.font-size-code;
                    font-family: Theme.font-mono;
                    wrap: word-wrap;
                    width: available-width - 4 * Theme.space-md;
                }
            }
        }
    }
}

// ── Heading ───────────────────────────────────────────────────────────────────

component HeadingBlock {
    in property <string> content;
    in property <int>    heading-level: 1;
    in property <length> available-width: 600px;

    width: available-width;

    VerticalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: Theme.space-xs;
        padding-bottom: Theme.space-xs;

        Text {
            text: content;
            color: Theme.text-primary;
            font-size: heading-level <= 1 ? Theme.font-size-lg
                     : heading-level <= 2 ? Theme.font-size-md
                     : Theme.font-size-base;
            font-weight: heading-level <= 2 ? 700 : 600;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }
    }
}

// ── List item ─────────────────────────────────────────────────────────────────

component ListItemBlock {
    in property <string> content;
    in property <int>    list-depth: 0;
    in property <length> available-width: 600px;

    width: available-width;

    HorizontalLayout {
        padding-left: Theme.space-md + list-depth * Theme.space-md;
        padding-right: Theme.space-md;
        spacing: Theme.space-xs;
        alignment: start;

        Text {
            text: "•";
            color: Theme.text-secondary;
            font-size: Theme.font-size-base;
        }

        Text {
            text: content;
            color: Theme.text-primary;
            font-size: Theme.font-size-base;
            wrap: word-wrap;
            width: available-width - Theme.space-md * (3 + list-depth);
        }
    }
}

// ── Block quote ───────────────────────────────────────────────────────────────

component BlockQuoteBlock {
    in property <string> content;
    in property <length> available-width: 600px;

    width: available-width;

    VerticalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: Theme.space-xs;
        padding-bottom: Theme.space-xs;

        HorizontalLayout {
            spacing: 0;

            Rectangle {
                width: 3px;
                height: quote-text.preferred-height;
                background: Theme.accent-dim;
            }

            Rectangle { width: Theme.space-sm; }

            quote-text := Text {
                text: content;
                color: Theme.text-secondary;
                font-size: Theme.font-size-base;
                wrap: word-wrap;
                width: available-width - Theme.space-md * 2 - 3px - Theme.space-sm;
            }
        }
    }
}

// ── Separator ─────────────────────────────────────────────────────────────────

component SeparatorBlock {
    in property <length> available-width: 600px;

    width: available-width;
    height: 16px;

    Rectangle {
        y: 7px;
        x: Theme.space-md;
        width: available-width - 2 * Theme.space-md;
        height: 1px;
        background: Theme.border;
    }
}

// ── Thinking bubble ───────────────────────────────────────────────────────────

component ThinkingBubble inherits Rectangle {
    in property <string> content;
    in property <bool>   is-expanded: true;
    in property <bool>   is-streaming: false;
    in property <length> available-width: 600px;

    callback toggle-expanded();

    width: available-width;
    border-radius: Theme.radius-md;
    background: Theme.thinking-bg;
    border-color: Theme.thinking-border;
    border-width: 1px;

    VerticalLayout {
        padding: Theme.space-md;
        spacing: Theme.space-xs;

        // Header: always visible, click to expand/collapse
        header-ta := TouchArea {
            height: header-row.preferred-height;
            clicked => { root.toggle-expanded(); }

            header-row := HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: start;

                Text {
                    text: is-expanded ? "▾ Thinking" : "▸ Thinking";
                    color: Theme.thinking-text;
                    font-size: Theme.font-size-sm;
                    font-weight: 600;
                }

                if is-streaming: Text {
                    text: "▋";
                    color: Theme.thinking-text;
                    font-size: Theme.font-size-sm;
                }

                // Preview when collapsed
                if !is-expanded && content != "": Text {
                    text: content;
                    color: Theme.thinking-text;
                    font-size: Theme.font-size-sm;
                    opacity: 0.6;
                    overflow: elide;
                    width: available-width - 200px;
                }
            }
        }

        // Full content — only shown when expanded
        if is-expanded: Text {
            text: content;
            color: Theme.thinking-text;
            font-size: Theme.font-size-sm;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }
    }
}

// ── Tool call bubble ─────────────────────────────────────────────────────────

component ToolCallBubble inherits Rectangle {
    in property <string> tool-name;
    in property <string> tool-icon: "▶";
    in property <string> tool-summary: "";
    in property <string> tool-category: "";
    in property <string> tool-fields-json: "[]";
    in property <bool>   is-expanded: false;
    in property <length> available-width: 600px;

    callback toggle-expanded();

    width: available-width;
    border-radius: Theme.radius-md;
    background: Theme.tool-bg;
    border-color: Theme.tool-border;
    border-width: 1px;

    VerticalLayout {
        padding: Theme.space-md;
        spacing: Theme.space-xs;

        // Header row — always visible
        header-ta := TouchArea {
            height: header-row.preferred-height;
            clicked => { root.toggle-expanded(); }

            header-row := HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: start;

                Text {
                    text: tool-icon + " " + tool-name;
                    color: Theme.tool-name-color;
                    font-size: Theme.font-size-sm;
                    font-weight: 700;
                }

                if tool-summary != "": Text {
                    text: "  " + tool-summary;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    overflow: elide;
                    width: available-width - 200px;
                }

                Text {
                    text: is-expanded ? " ▾" : " ▸";
                    color: Theme.text-dim;
                    font-size: Theme.font-size-sm;
                }
            }
        }

        // Expanded detail view
        if is-expanded && tool-fields-json != "[]" && tool-fields-json != "": Text {
            text: tool-fields-json;
            color: Theme.text-secondary;
            font-size: Theme.font-size-code;
            font-family: Theme.font-mono;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }
    }
}

// ── Tool result bubble ────────────────────────────────────────────────────────

component ToolResultBubble inherits Rectangle {
    in property <string> content;
    in property <bool>   is-error;
    in property <bool>   is-expanded: false;
    in property <length> available-width: 600px;

    callback toggle-expanded();

    width: available-width;
    border-radius: Theme.radius-md;
    background: is-error ? Theme.error-bg : Theme.tool-bg;
    border-color: is-error ? Theme.error-border : Theme.tool-border;
    border-width: 1px;

    VerticalLayout {
        padding: Theme.space-md;
        spacing: Theme.space-xs;

        header-ta := TouchArea {
            height: header-row.preferred-height;
            clicked => { root.toggle-expanded(); }

            header-row := HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: start;
                Text {
                    text: is-error ? "✕ Error" : (is-expanded ? "▾ Result" : "▸ Result");
                    color: is-error ? Theme.error-text : Theme.success;
                    font-size: Theme.font-size-sm;
                    font-weight: 600;
                }
            }
        }

        if is-expanded: Text {
            text: content;
            color: is-error ? Theme.error-text : Theme.text-secondary;
            font-size: Theme.font-size-code;
            font-family: Theme.font-mono;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }
    }
}

// ── Error bubble ──────────────────────────────────────────────────────────────

component ErrorBubble inherits Rectangle {
    in property <string> content;
    in property <length> available-width: 600px;

    width: available-width;
    border-radius: Theme.radius-md;
    background: Theme.error-bg;
    border-color: Theme.error-border;
    border-width: 1px;

    VerticalLayout {
        padding: Theme.space-md;
        Text {
            text: "✕ " + content;
            color: Theme.error-text;
            font-size: Theme.font-size-base;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }
    }
}

// ── System event ──────────────────────────────────────────────────────────────

component SystemEventRow {
    in property <string> content;
    in property <length> available-width: 600px;

    width: available-width;
    height: 28px;

    Text {
        text: content;
        color: Theme.text-dim;
        font-size: Theme.font-size-sm;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

// ── Welcome screen ────────────────────────────────────────────────────────────

export component WelcomeScreen {
    VerticalLayout {
        alignment: center;
        spacing: Theme.space-lg;

        Text {
            text: "⬡";
            font-size: 48px;
            color: Theme.accent;
            horizontal-alignment: center;
        }

        Text {
            text: "Sven Desktop";
            font-size: 24px;
            font-weight: 700;
            color: Theme.text-primary;
            horizontal-alignment: center;
        }

        Text {
            text: "An efficient AI coding agent";
            font-size: Theme.font-size-base;
            color: Theme.text-secondary;
            horizontal-alignment: center;
        }

        Text {
            text: "Type a message below to start";
            font-size: Theme.font-size-sm;
            color: Theme.text-dim;
            horizontal-alignment: center;
        }
    }
}

// ── Message row dispatching ───────────────────────────────────────────────────

component MessageRow inherits VerticalLayout {
    in property <ChatMessage> msg;
    in property <int>         msg-index;
    in property <length>      available-width: 600px;

    callback toggle-expanded(int);

    alignment: start;

    if msg.message-type == "user": UserBubble {
        content: msg.content;
        available-width: available-width;
    }
    if msg.message-type == "assistant": AssistantParagraph {
        content: msg.content;
        is-streaming: msg.is-streaming;
        show-header: msg.is-first-in-group;
        available-width: available-width;
    }
    if msg.message-type == "code-block": CodeBlockBubble {
        content: msg.content;
        language: msg.language;
        available-width: available-width;
    }
    if msg.message-type == "heading": HeadingBlock {
        content: msg.content;
        heading-level: msg.heading-level;
        available-width: available-width;
    }
    if msg.message-type == "list-item": ListItemBlock {
        content: msg.content;
        list-depth: msg.heading-level; // repurposed field: depth
        available-width: available-width;
    }
    if msg.message-type == "block-quote": BlockQuoteBlock {
        content: msg.content;
        available-width: available-width;
    }
    if msg.message-type == "separator": SeparatorBlock {
        available-width: available-width;
    }
    if msg.message-type == "thinking": ThinkingBubble {
        content: msg.content;
        is-expanded: msg.is-expanded;
        available-width: available-width;
        toggle-expanded => { root.toggle-expanded(msg-index); }
    }
    if msg.message-type == "tool-call": ToolCallBubble {
        tool-name: msg.tool-name;
        tool-icon: msg.tool-icon;
        tool-summary: msg.tool-summary;
        tool-category: msg.tool-category;
        tool-fields-json: msg.tool-fields-json;
        is-expanded: msg.is-expanded;
        available-width: available-width;
        toggle-expanded => { root.toggle-expanded(msg-index); }
    }
    if msg.message-type == "tool-result": ToolResultBubble {
        content: msg.content;
        is-error: msg.is-error;
        is-expanded: msg.is-expanded;
        available-width: available-width;
        toggle-expanded => { root.toggle-expanded(msg-index); }
    }
    if msg.message-type == "error": ErrorBubble {
        content: msg.content;
        available-width: available-width;
    }
    if msg.message-type == "system": SystemEventRow {
        content: msg.content;
        available-width: available-width;
    }
}

// ── Main chat pane ────────────────────────────────────────────────────────────

export component ChatPane inherits Rectangle {
    in property <[ChatMessage]> messages;
    in property <string> streaming-text: "";
    in property <string> thinking-text: "";

    callback toggle-expanded(int);

    background: Theme.bg-deep;
    clip: true;

    property <bool> has-content: messages.length > 0
                                  || streaming-text != ""
                                  || thinking-text != "";

    if !has-content: WelcomeScreen {
        width: parent.width;
        height: parent.height;
    }

    if has-content: Flickable {
        width: parent.width;
        height: parent.height;
        interactive: true;
        viewport-height: content-layout.preferred-height;

        content-layout := VerticalLayout {
            width: parent.width;
            padding: Theme.space-lg;
            spacing: Theme.space-xs;
            alignment: start;

            for msg[i] in messages: MessageRow {
                msg: msg;
                msg-index: i;
                available-width: parent.width - 2 * Theme.space-lg;
                toggle-expanded(idx) => { root.toggle-expanded(idx); }
            }

            // Live thinking stream
            if thinking-text != "": ThinkingBubble {
                content: thinking-text;
                is-expanded: true;
                is-streaming: true;
                available-width: parent.width - 2 * Theme.space-lg;
            }

            // Live response stream
            if streaming-text != "": AssistantParagraph {
                content: streaming-text;
                is-streaming: true;
                show-header: thinking-text == "";
                available-width: parent.width - 2 * Theme.space-lg;
            }
        }
    }
}
