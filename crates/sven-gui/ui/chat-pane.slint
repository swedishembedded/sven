//
// Scrollable chat message pane with rich markdown block rendering.

import { Theme } from "theme.slint";
import { IconButton, HDivider } from "widgets.slint";

// ── Syntax-highlight types ────────────────────────────────────────────────────

export struct CodeToken {
    text: string,
    color: color,
}

export struct CodeLine {
    tokens: [CodeToken],
}

// ── Inline text run ───────────────────────────────────────────────────────────

export struct TextRun {
    text: string,
    bold: bool,
    italic: bool,
    is-code: bool,
    is-link: bool,
    url: string,
}

// ── Chat message struct ───────────────────────────────────────────────────────

export struct ChatMessage {
    // Core classification
    message-type: string,   // user|assistant|inline-code|code-block|heading|list-item|separator|thinking|tool-call|tool-result|error|system|block-quote|table-row
    content: string,
    role: string,

    // Group header
    is-first-in-group: bool,

    // State
    is-error: bool,
    is-streaming: bool,
    is-expanded: bool,
    is-search-match: bool,

    // Tool call fields
    tool-name: string,
    tool-icon: string,
    tool-summary: string,
    tool-category: string,
    tool-fields-json: string,

    // Code block fields
    language: string,
    heading-level: int,

    // Syntax-highlighted lines (populated for code-block type)
    code-lines: [CodeLine],

    // Inline text runs (populated for assistant paragraphs with formatting)
    text-runs: [TextRun],

    // Table cells (populated for table-row type)
    cells: [string],
}

// ── User bubble ───────────────────────────────────────────────────────────────

component UserBubble inherits Rectangle {
    in property <string>     content;
    in property <[TextRun]> text-runs;
    in property <length>     available-width: 600px;
    in property <int>        msg-index: 0;
    in property <bool>       is-search-match: false;

    callback edit-clicked();
    callback copy-clicked(string);

    width: available-width;
    border-radius: Theme.radius-md;
    background: is-search-match ? Theme.accent-glow : Theme.user-msg-bg;
    border-color: is-search-match ? Theme.accent : Theme.user-msg-border;
    border-width: 1px;
    animate background { duration: Theme.duration-fast; }

    VerticalLayout {
        padding: Theme.space-md;
        spacing: Theme.space-xs;

        HorizontalLayout {
            alignment: space-between;
            spacing: Theme.space-sm;

            HorizontalLayout {
                spacing: Theme.space-sm;
                alignment: start;
                Text {
                    text: "You";
                    color: Theme.info;
                    font-size: Theme.font-size-sm;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }

            HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: end;
                opacity: action-area.has-hover ? 1.0 : 0.0;
                animate opacity { duration: Theme.duration-fast; }

                action-area := TouchArea {
                    width: 0;
                    height: 0;
                }

                IconButton {
                    icon: "⎘";
                    tooltip-text: "Copy message";
                    clicked => { root.copy-clicked(root.content); }
                }
                IconButton {
                    icon: "✎";
                    tooltip-text: "Edit message";
                    clicked => { root.edit-clicked(); }
                }
            }
        }

        // Plain content when no runs, or long content (ensure wrapping)
        if text-runs.length == 0 || content.character-count > 120: Text {
            text: content;
            color: Theme.text-primary;
            font-size: Theme.font-size-base;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }

        // Rich inline formatting for short content (bold, italic, code, links)
        if text-runs.length > 0 && content.character-count <= 120: HorizontalLayout {
            spacing: 0;
            alignment: start;
            width: available-width - 2 * Theme.space-md;

            for run in text-runs: Rectangle {
                height: run-text.preferred-height;
                width: Math.min(run-text.preferred-width + (run.is-code ? 4px : 0px),
                               available-width - 2 * Theme.space-md);
                border-radius: run.is-code ? Theme.radius-sm : 0;
                background: run.is-code ? Theme.inline-code-bg : transparent;
                border-color: run.is-code ? Theme.code-border : transparent;
                border-width: run.is-code ? 1px : 0px;

                run-text := Text {
                    x: run.is-code ? 2px : 0;
                    text: run.text;
                    color: run.is-code ? Theme.text-code :
                           run.is-link ? Theme.text-link :
                           Theme.text-primary;
                    font-size: Theme.font-size-base;
                    font-weight: run.bold ? 700 : 400;
                    font-family: run.is-code ? Theme.font-mono : Theme.font-ui;
                    wrap: word-wrap;
                    width: parent.width - (run.is-code ? 4px : 0px);
                }
            }
        }
    }
}

// ── Rich-text paragraph ───────────────────────────────────────────────────────
// Renders a paragraph with inline text runs when available.

component RichParagraph inherits Rectangle {
    in property <string>     content;
    in property <[TextRun]>  text-runs;
    in property <bool>       is-streaming: false;
    in property <bool>       show-header: false;
    in property <bool>       is-bold: false;
    in property <bool>       is-search-match: false;
    in property <length>     available-width: 600px;

    callback copy-clicked(string);

    width: available-width;
    background: is-search-match ? Theme.accent-glow : transparent;
    animate background { duration: Theme.duration-fast; }

    VerticalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: show-header ? Theme.space-md : 0;
        padding-bottom: Theme.space-xs;
        spacing: Theme.space-xs;

        if show-header: HorizontalLayout {
            spacing: Theme.space-xs;
            alignment: space-between;
            HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: start;
                Text {
                    text: "⬡ Sven";
                    color: Theme.accent;
                    font-size: Theme.font-size-sm;
                    font-weight: 700;
                }
                if is-streaming: Text {
                    text: "▋";
                    color: Theme.accent;
                    font-size: Theme.font-size-sm;
                }
            }
        }

        // Render plain content when no runs, or when content is long (ensure wrapping)
        // Long content with runs would overflow in HorizontalLayout; use plain Text to fit.
        if text-runs.length == 0 || content.character-count > 120: Text {
            text: content;
            color: Theme.text-primary;
            font-size: Theme.font-size-base;
            font-weight: is-bold ? 700 : 400;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }

        // Render inline runs for short content (bold, italic, code, links)
        if text-runs.length > 0 && content.character-count <= 120: HorizontalLayout {
            spacing: 0;
            alignment: start;
            width: available-width - 2 * Theme.space-md;

            for run in text-runs: Rectangle {
                height: run-text.preferred-height;
                width: Math.min(run-text.preferred-width + (run.is-code ? 4px : 0px),
                               available-width - 2 * Theme.space-md);
                border-radius: run.is-code ? Theme.radius-sm : 0;
                background: run.is-code ? Theme.inline-code-bg : transparent;
                border-color: run.is-code ? Theme.code-border : transparent;
                border-width: run.is-code ? 1px : 0px;

                run-text := Text {
                    x: run.is-code ? 2px : 0;
                    text: run.text;
                    color: run.is-code ? Theme.text-code :
                           run.is-link ? Theme.text-link :
                           Theme.text-primary;
                    font-size: Theme.font-size-base;
                    font-weight: run.bold ? 700 : 400;
                    font-family: run.is-code ? Theme.font-mono : Theme.font-ui;
                    wrap: word-wrap;
                    width: parent.width - (run.is-code ? 4px : 0px);
                }
            }
        }
    }
}

// ── Assistant paragraph (streaming / simple) ──────────────────────────────────

export component AssistantParagraph inherits Rectangle {
    in property <string>     content;
    in property <[TextRun]>  text-runs;
    in property <bool>       is-streaming: false;
    in property <bool>       show-header: false;
    in property <bool>       is-search-match: false;
    in property <length>     available-width: 600px;

    callback copy-clicked(string);

    width: available-width;

    RichParagraph {
        content: root.content;
        text-runs: root.text-runs;
        is-streaming: root.is-streaming;
        show-header: root.show-header;
        is-search-match: root.is-search-match;
        available-width: root.available-width;
        copy-clicked(t) => { root.copy-clicked(t); }
    }
}

// ── Inline code ───────────────────────────────────────────────────────────────

component InlineCodeBlock inherits Rectangle {
    in property <string> content;
    in property <length> available-width: 600px;

    width: available-width;

    HorizontalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: Theme.space-xs;
        padding-bottom: Theme.space-xs;

        Rectangle {
            border-radius: Theme.radius-sm;
            background: Theme.inline-code-bg;
            border-color: Theme.code-border;
            border-width: 1px;
            height: inline-code-text.preferred-height + 6px;
            width: inline-code-text.preferred-width + 10px;

            inline-code-text := Text {
                x: 5px;
                y: 3px;
                text: content;
                color: Theme.text-code;
                font-size: Theme.font-size-code;
                font-family: Theme.font-mono;
            }
        }
    }
}

// ── Code block with syntax highlighting ───────────────────────────────────────

component CodeBlockBubble {
    in property <string>     content;
    in property <string>     language: "";
    in property <[CodeLine]> code-lines;
    in property <length>     available-width: 600px;

    callback copy-clicked(string);

    property <bool> has-highlight: code-lines.length > 0;
    property <int>  line-count: has-highlight ? code-lines.length : content.character-count;

    width: available-width;

    VerticalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-bottom: Theme.space-xs;

        block-rect := Rectangle {
            border-radius: Theme.radius-sm;
            background: Theme.code-bg;
            border-color: Theme.code-border;
            border-width: 1px;

            VerticalLayout {
                padding-top: Theme.space-xs;
                padding-bottom: Theme.space-sm;
                padding-left: Theme.space-sm;
                padding-right: Theme.space-sm;
                spacing: 0;

                // Language bar with copy button
                Rectangle {
                    height: 28px;
                    border-radius: Theme.radius-sm;
                    background: transparent;

                    HorizontalLayout {
                        alignment: space-between;
                        padding-left: Theme.space-xs;
                        padding-right: Theme.space-xs;

                        Text {
                            text: language != "" ? language : "text";
                            color: Theme.accent-dim;
                            font-size: Theme.font-size-xs;
                            font-family: Theme.font-mono;
                            vertical-alignment: center;
                        }

                        HorizontalLayout {
                            spacing: Theme.space-xs;
                            alignment: end;

                            IconButton {
                                icon: "⎘";
                                tooltip-text: "Copy code";
                                icon-color: Theme.text-dim;
                                hover-bg: Theme.bg-hover;
                                clicked => { root.copy-clicked(root.content); }
                            }
                        }
                    }
                }

                // Highlighted lines
                if has-highlight: Flickable {
                    width: parent.width - 2 * Theme.space-sm;
                    height: Math.min(line-count * (Theme.font-size-code + 4px), 480px);
                    viewport-width: code-lines-layout.preferred-width;
                    viewport-height: code-lines-layout.preferred-height;
                    interactive: true;

                    code-lines-layout := VerticalLayout {
                        spacing: 0;
                        alignment: start;

                        for line in code-lines: HorizontalLayout {
                            alignment: start;
                            spacing: 0;
                            height: Theme.font-size-code + 4px;

                            for token in line.tokens: Text {
                                text: token.text;
                                color: token.color;
                                font-size: Theme.font-size-code;
                                font-family: Theme.font-mono;
                                vertical-alignment: center;
                                wrap: no-wrap;
                            }
                        }
                    }
                }

                // Fallback plain text
                if !has-highlight: Flickable {
                    width: parent.width - 2 * Theme.space-sm;
                    height: Math.min(content.character-count / 80 * (Theme.font-size-code + 4px) + Theme.font-size-code, 480px);
                    viewport-width: fallback-text.preferred-width;
                    viewport-height: fallback-text.preferred-height;
                    interactive: true;

                    fallback-text := Text {
                        text: content;
                        color: Theme.text-code;
                        font-size: Theme.font-size-code;
                        font-family: Theme.font-mono;
                        wrap: no-wrap;
                    }
                }
            }
        }
    }
}

// ── Heading ───────────────────────────────────────────────────────────────────

component HeadingBlock {
    in property <string> content;
    in property <int>    heading-level: 1;
    in property <length> available-width: 600px;

    width: available-width;

    VerticalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: Theme.space-sm;
        padding-bottom: Theme.space-xs;

        Text {
            text: content;
            color: Theme.text-primary;
            font-size:
                heading-level <= 1 ? Theme.font-size-h1 :
                heading-level <= 2 ? Theme.font-size-h2 :
                heading-level <= 3 ? Theme.font-size-h3 :
                heading-level <= 4 ? Theme.font-size-h4 :
                Theme.font-size-h5;
            font-weight: heading-level <= 3 ? 700 : 600;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
        }

        // Underline for h1/h2
        if heading-level <= 2: HDivider { width: available-width - 2 * Theme.space-md; }
    }
}

// ── List item ─────────────────────────────────────────────────────────────────

component ListItemBlock {
    in property <string>    content;
    in property <[TextRun]> text-runs;
    in property <int>       list-depth: 0;
    in property <length>    available-width: 600px;

    width: available-width;

    HorizontalLayout {
        padding-left: Theme.space-md + list-depth * Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: 2px;
        padding-bottom: 2px;
        spacing: Theme.space-xs;
        alignment: start;

        Text {
            text: list-depth == 0 ? "•" : "◦";
            color: Theme.accent-dim;
            font-size: Theme.font-size-base;
            vertical-alignment: top;
            y: 2px;
            width: 14px;
        }

        if text-runs.length == 0 || content.character-count > 120: Text {
            text: content;
            color: Theme.text-primary;
            font-size: Theme.font-size-base;
            wrap: word-wrap;
            width: available-width - Theme.space-md * (3 + list-depth) - 14px;
        }

        if text-runs.length > 0 && content.character-count <= 120: HorizontalLayout {
            spacing: 0;
            alignment: start;
            width: available-width - Theme.space-md * (3 + list-depth) - 14px;

            for run in text-runs: Rectangle {
                height: run-text.preferred-height;
                width: Math.min(run-text.preferred-width + (run.is-code ? 4px : 0px),
                               available-width - Theme.space-md * (3 + list-depth) - 14px);
                border-radius: run.is-code ? Theme.radius-sm : 0;
                background: run.is-code ? Theme.inline-code-bg : transparent;
                border-width: run.is-code ? 1px : 0px;
                border-color: run.is-code ? Theme.code-border : transparent;

                run-text := Text {
                    x: run.is-code ? 2px : 0;
                    text: run.text;
                    color: run.is-code ? Theme.text-code :
                           run.is-link ? Theme.text-link :
                           Theme.text-primary;
                    font-size: Theme.font-size-base;
                    font-weight: run.bold ? 700 : 400;
                    font-family: run.is-code ? Theme.font-mono : Theme.font-ui;
                    wrap: word-wrap;
                    width: parent.width - (run.is-code ? 4px : 0px);
                }
            }
        }
    }
}

// ── Block quote ───────────────────────────────────────────────────────────────

component BlockQuoteBlock {
    in property <string> content;
    in property <length> available-width: 600px;

    width: available-width;

    VerticalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: Theme.space-xs;
        padding-bottom: Theme.space-xs;

        HorizontalLayout {
            spacing: 0;

            Rectangle {
                width: 3px;
                height: quote-text.preferred-height;
                background: Theme.accent-dim;
                border-radius: 2px;
            }

            Rectangle { width: Theme.space-sm; }

            quote-text := Text {
                text: content;
                color: Theme.text-secondary;
                font-size: Theme.font-size-base;
                font-family: Theme.font-ui;
                wrap: word-wrap;
                width: available-width - Theme.space-md * 2 - 3px - Theme.space-sm;
            }
        }
    }
}

// ── Separator ─────────────────────────────────────────────────────────────────

component SeparatorBlock {
    in property <length> available-width: 600px;
    width: available-width;
    height: 16px;

    Rectangle {
        y: 7px;
        x: Theme.space-md;
        width: available-width - 2 * Theme.space-md;
        height: 1px;
        background: Theme.border;
    }
}

// ── Table row ─────────────────────────────────────────────────────────────────

component TableRowBlock {
    in property <[string]> cells;
    in property <string>   content;  // fallback
    in property <bool>     is-header: false;
    in property <length>   available-width: 600px;

    width: available-width;
    height: row-layout.preferred-height;

    row-layout := HorizontalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: Theme.space-xs;
        padding-bottom: Theme.space-xs;
        spacing: 0;
        alignment: start;

        // Render cells if available
        if cells.length > 0: HorizontalLayout {
            spacing: 0;
            alignment: start;
            for cell in cells: Rectangle {
                horizontal-stretch: 1;
                border-color: Theme.border-dim;
                border-width: 1px;
                background: is-header ? Theme.bg-card : transparent;

                Text {
                    x: Theme.space-xs;
                    y: Theme.space-xs;
                    width: parent.width - Theme.space-xs * 2;
                    text: cell;
                    color: is-header ? Theme.text-primary : Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    font-weight: is-header ? 600 : 400;
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                }
            }
        }

        // Fallback to content string
        if cells.length == 0: Text {
            text: content;
            color: Theme.text-secondary;
            font-size: Theme.font-size-sm;
            wrap: word-wrap;
            horizontal-stretch: 1;
        }
    }
}

// ── Thinking bubble ───────────────────────────────────────────────────────────

component ThinkingBubble inherits Rectangle {
    in property <string> content;
    in property <bool>   is-expanded: true;
    in property <bool>   is-streaming: false;
    in property <length> available-width: 600px;

    callback toggle-expanded();

    width: available-width;
    border-radius: Theme.radius-md;
    background: Theme.thinking-bg;
    border-color: Theme.thinking-border;
    border-width: 1px;

    VerticalLayout {
        padding: Theme.space-md;
        spacing: Theme.space-xs;

        header-ta := TouchArea {
            height: header-row.preferred-height;
            clicked => { root.toggle-expanded(); }

            header-row := HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: start;

                Text {
                    text: is-expanded ? "▾ Thinking" : "▸ Thinking";
                    color: Theme.thinking-text;
                    font-size: Theme.font-size-sm;
                    font-weight: 600;
                }

                if is-streaming: Text {
                    text: "▋";
                    color: Theme.thinking-text;
                    font-size: Theme.font-size-sm;
                }

                if !is-expanded && !is-streaming && content != "": Text {
                    text: content;
                    color: Theme.thinking-text;
                    font-size: Theme.font-size-sm;
                    opacity: 0.6;
                    overflow: elide;
                    wrap: no-wrap;
                    height: Theme.font-size-sm + 2px;
                    width: available-width - 180px;
                }
            }
        }

        if is-expanded: Rectangle {
            clip: true;
            height: expanded-text.preferred-height;
            // No height animation — during streaming, height changes on every text delta;
            // animating would restart each time and look jarring. Content grows instantly.

            expanded-text := Text {
                text: content;
                color: Theme.thinking-text;
                font-size: Theme.font-size-sm;
                wrap: word-wrap;
                width: available-width - 2 * Theme.space-md;
            }
        }
    }
}

// ── Tool call bubble ──────────────────────────────────────────────────────────

component ToolCallBubble inherits Rectangle {
    in property <string> tool-name;
    in property <string> tool-icon: "▶";
    in property <string> tool-summary: "";
    in property <string> tool-category: "";
    in property <string> tool-fields-json: "";
    in property <bool>   is-expanded: false;
    in property <length> available-width: 600px;

    callback toggle-expanded();

    width: available-width;
    border-radius: Theme.radius-md;
    background: Theme.tool-bg;
    border-color: Theme.tool-border;
    border-width: 1px;

    VerticalLayout {
        padding: Theme.space-md;
        spacing: Theme.space-xs;

        header-ta := TouchArea {
            height: header-row.preferred-height;
            clicked => { root.toggle-expanded(); }

            header-row := HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: start;

                Text {
                    text: tool-icon + " " + tool-name;
                    color: Theme.tool-name-color;
                    font-size: Theme.font-size-sm;
                    font-weight: 700;
                }

                if tool-summary != "": Text {
                    text: "  " + tool-summary;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    overflow: elide;
                    width: available-width - 240px;
                }

                Text {
                    text: is-expanded ? " ▾" : " ▸";
                    color: Theme.text-dim;
                    font-size: Theme.font-size-sm;
                }
            }
        }

        if is-expanded && tool-fields-json != "": Rectangle {
            clip: true;
            height: fields-text.preferred-height;
            animate height { duration: Theme.duration-normal; easing: ease-in-out; }

            fields-text := Text {
                text: tool-fields-json;
                color: Theme.text-secondary;
                font-size: Theme.font-size-code;
                font-family: Theme.font-mono;
                wrap: word-wrap;
                width: available-width - 2 * Theme.space-md;
            }
        }
    }
}

// ── Tool result bubble ────────────────────────────────────────────────────────

component ToolResultBubble inherits Rectangle {
    in property <string> content;
    in property <bool>   is-error;
    in property <bool>   is-expanded: false;
    in property <length> available-width: 600px;

    callback toggle-expanded();

    width: available-width;
    border-radius: Theme.radius-md;
    background: is-error ? Theme.error-bg : Theme.tool-bg;
    border-color: is-error ? Theme.error-border : Theme.tool-border;
    border-width: 1px;

    VerticalLayout {
        padding: Theme.space-md;
        spacing: Theme.space-xs;

        header-ta := TouchArea {
            height: header-row.preferred-height;
            clicked => { root.toggle-expanded(); }

            header-row := HorizontalLayout {
                spacing: Theme.space-xs;
                alignment: start;
                Text {
                    text: is-error ? "✕ Error" : (is-expanded ? "▾ Result" : "▸ Result");
                    color: is-error ? Theme.error-text : Theme.success;
                    font-size: Theme.font-size-sm;
                    font-weight: 600;
                }
            }
        }

        if is-error: Text {
            text: content;
            color: Theme.error-text;
            font-size: Theme.font-size-sm;
            font-family: Theme.font-mono;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
            opacity: 0.85;
        }

        if !is-error && is-expanded: Rectangle {
            clip: true;
            height: result-text.preferred-height;
            animate height { duration: Theme.duration-normal; easing: ease-in-out; }

            result-text := Text {
                text: content;
                color: Theme.text-secondary;
                font-size: Theme.font-size-code;
                font-family: Theme.font-mono;
                wrap: word-wrap;
                width: available-width - 2 * Theme.space-md;
            }
        }
    }
}

// ── Error bubble ──────────────────────────────────────────────────────────────

component ErrorBubble inherits Rectangle {
    in property <string> content;
    in property <length> available-width: 600px;

    width: available-width;
    border-radius: Theme.radius-md;
    background: Theme.error-bg;
    border-color: Theme.error-border;
    border-width: 1px;

    VerticalLayout {
        padding: Theme.space-md;
        spacing: Theme.space-xs;

        HorizontalLayout {
            spacing: Theme.space-xs;
            alignment: start;
            Text {
                text: "✕ Error";
                color: Theme.error-text;
                font-size: Theme.font-size-sm;
                font-weight: 700;
            }
        }

        Text {
            text: content;
            color: Theme.error-text;
            font-size: Theme.font-size-base;
            wrap: word-wrap;
            width: available-width - 2 * Theme.space-md;
            opacity: 0.9;
        }
    }
}

// ── System event ──────────────────────────────────────────────────────────────

component SystemEventRow {
    in property <string> content;
    in property <length> available-width: 600px;

    width: available-width;
    height: Theme.row-height;

    Text {
        text: content;
        color: Theme.text-dim;
        font-size: Theme.font-size-sm;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

// ── Welcome screen ────────────────────────────────────────────────────────────

export component WelcomeScreen {
    VerticalLayout {
        alignment: center;
        spacing: Theme.space-lg;

        Text {
            text: "⬡";
            font-size: 48px;
            color: Theme.accent;
            horizontal-alignment: center;
        }

        Text {
            text: "Sven Desktop";
            font-size: Theme.font-size-h1;
            font-weight: 700;
            color: Theme.text-primary;
            horizontal-alignment: center;
        }

        Text {
            text: "An efficient AI coding agent";
            font-size: Theme.font-size-base;
            color: Theme.text-secondary;
            horizontal-alignment: center;
        }

        Text {
            text: "Type a message below to start · / for commands · F1 for help";
            font-size: Theme.font-size-sm;
            color: Theme.text-dim;
            horizontal-alignment: center;
        }
    }
}

// ── Message row dispatching ───────────────────────────────────────────────────

export component MessageRow inherits VerticalLayout {
    in property <ChatMessage> msg;
    in property <int>         msg-index;
    in property <length>      available-width: 600px;

    callback toggle-expanded(int);
    callback edit-clicked(int);
    callback copy-text(string);

    alignment: start;

    if msg.message-type == "user": UserBubble {
        content: msg.content;
        text-runs: msg.text-runs;
        available-width: available-width;
        msg-index: msg-index;
        is-search-match: msg.is-search-match;
        edit-clicked => { root.edit-clicked(msg-index); }
        copy-clicked(t) => { root.copy-text(t); }
    }
    if msg.message-type == "assistant": AssistantParagraph {
        content: msg.content;
        text-runs: msg.text-runs;
        is-streaming: msg.is-streaming;
        show-header: msg.is-first-in-group;
        is-search-match: msg.is-search-match;
        available-width: available-width;
        copy-clicked(t) => { root.copy-text(t); }
    }
    if msg.message-type == "inline-code": InlineCodeBlock {
        content: msg.content;
        available-width: available-width;
    }
    if msg.message-type == "code-block": CodeBlockBubble {
        content: msg.content;
        language: msg.language;
        code-lines: msg.code-lines;
        available-width: available-width;
        copy-clicked(t) => { root.copy-text(t); }
    }
    if msg.message-type == "heading": HeadingBlock {
        content: msg.content;
        heading-level: msg.heading-level;
        available-width: available-width;
    }
    if msg.message-type == "list-item": ListItemBlock {
        content: msg.content;
        text-runs: msg.text-runs;
        list-depth: msg.heading-level;
        available-width: available-width;
    }
    if msg.message-type == "block-quote": BlockQuoteBlock {
        content: msg.content;
        available-width: available-width;
    }
    if msg.message-type == "separator": SeparatorBlock {
        available-width: available-width;
    }
    if msg.message-type == "table-row": TableRowBlock {
        cells: msg.cells;
        content: msg.content;
        available-width: available-width;
    }
    if msg.message-type == "thinking": ThinkingBubble {
        content: msg.content;
        is-expanded: msg.is-expanded;
        available-width: available-width;
        toggle-expanded => { root.toggle-expanded(msg-index); }
    }
    if msg.message-type == "tool-call": ToolCallBubble {
        tool-name: msg.tool-name;
        tool-icon: msg.tool-icon;
        tool-summary: msg.tool-summary;
        tool-category: msg.tool-category;
        tool-fields-json: msg.tool-fields-json;
        is-expanded: msg.is-expanded;
        available-width: available-width;
        toggle-expanded => { root.toggle-expanded(msg-index); }
    }
    if msg.message-type == "tool-result": ToolResultBubble {
        content: msg.content;
        is-error: msg.is-error;
        is-expanded: msg.is-expanded;
        available-width: available-width;
        toggle-expanded => { root.toggle-expanded(msg-index); }
    }
    if msg.message-type == "error": ErrorBubble {
        content: msg.content;
        available-width: available-width;
    }
    if msg.message-type == "system": SystemEventRow {
        content: msg.content;
        available-width: available-width;
    }
}

// ── Main chat pane ────────────────────────────────────────────────────────────

export component ChatPane inherits Rectangle {
    in property <[ChatMessage]> messages;
    in property <[ChatMessage]> streaming-messages;
    in property <string>        streaming-text: "";
    in property <string>        thinking-text: "";
    in property <int>           search-match-row: -1;
    // Toggle this to trigger a scroll-to-bottom
    in-out property <bool>      scroll-bottom-trigger: false;

    callback toggle-expanded(int);
    callback message-edit-requested(int);
    callback copy-text(string);

    background: Theme.bg-deep;
    clip: true;

    property <bool> has-content: messages.length > 0
                                  || streaming-messages.length > 0
                                  || streaming-text != ""
                                  || thinking-text != "";

    if !has-content: WelcomeScreen {
        width: parent.width;
        height: parent.height;
    }

    if has-content: flick := Flickable {
        width: parent.width;
        height: parent.height;
        interactive: true;
        viewport-height: content-layout.preferred-height;

        // Auto-scroll: when viewport grows (new content arrives), scroll to
        // bottom if user was already near the bottom.
        property <length> _prev-height: 0;
        changed viewport-height => {
            if (-self.viewport-y >= self._prev-height - self.height - 80px
                    || self._prev-height == 0px) {
                self.viewport-y = -(self.viewport-height - self.height);
            }
            self._prev-height = self.viewport-height;
        }

        content-layout := VerticalLayout {
            width: parent.width;
            padding: Theme.space-lg;
            spacing: Theme.space-xs;
            alignment: start;

            for msg[i] in messages: MessageRow {
                msg: msg;
                msg-index: i;
                available-width: parent.width - 2 * Theme.space-lg;
                toggle-expanded(idx) => { root.toggle-expanded(idx); }
                edit-clicked(idx) => { root.message-edit-requested(idx); }
                copy-text(t) => { root.copy-text(t); }
            }

            // Live response stream
            for msg[i] in streaming-messages: MessageRow {
                msg: msg;
                msg-index: -1;
                available-width: parent.width - 2 * Theme.space-lg;
                toggle-expanded(idx) => { }
                copy-text(t) => { root.copy-text(t); }
            }

            // Fallback streaming text
            if streaming-messages.length == 0 && streaming-text != "": AssistantParagraph {
                content: streaming-text;
                is-streaming: true;
                show-header: thinking-text == "";
                available-width: parent.width - 2 * Theme.space-lg;
            }

            // Live thinking stream
            if thinking-text != "": ThinkingBubble {
                content: thinking-text;
                is-expanded: true;
                is-streaming: true;
                available-width: parent.width - 2 * Theme.space-lg;
            }
        }
    }
}
